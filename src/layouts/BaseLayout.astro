---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
const { title, description = '', ogImage = '/og-default.jpg', noindex = false } = Astro.props;
---
<html lang="ka">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | სკოლა ნობელი</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={Astro.url} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={Astro.url} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+Georgian:wght@400;500;700&display=swap" />
</head>
<body class="font-sans antialiased">
  <Navbar />
  <slot />

  <!-- Floating contact buttons -->
  <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
    <a
      href="https://wa.me/995551145362"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-3 bg-white rounded-full shadow-lg pl-4 pr-1.5 py-1.5 hover:shadow-xl transition-all hover:-translate-y-0.5 group"
    >
      <span class="text-sm font-medium text-[#2C2C2C] group-hover:text-[#25D366] whitespace-nowrap">WhatsApp</span>
      <div class="w-11 h-11 bg-[#25D366] rounded-full flex items-center justify-center flex-shrink-0">
        <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </div>
    </a>
    <a
      href="https://m.me/Kids.Nobel"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-3 bg-white rounded-full shadow-lg pl-4 pr-1.5 py-1.5 hover:shadow-xl transition-all hover:-translate-y-0.5 group"
    >
      <span class="text-sm font-medium text-[#2C2C2C] group-hover:text-[#0084FF] whitespace-nowrap">Messenger</span>
      <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #0084FF, #A033FF)">
        <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24">
          <path d="M12 0C5.373 0 0 4.974 0 11.111c0 3.498 1.744 6.614 4.469 8.683V24l4.088-2.242c1.092.3 2.246.464 3.443.464 6.627 0 12-4.974 12-11.111S18.627 0 12 0zm1.191 14.963l-3.055-3.26-5.963 3.26L10.732 8l3.131 3.259L19.752 8l-6.561 6.963z"/>
        </svg>
      </div>
    </a>
  </div>

</body>
</html>