  <style>
    @keyframes float-slow {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-18px); }
    }
    .shape-float { animation: float-slow 8s ease-in-out infinite; }
    .reveal-up, .reveal-left, .reveal-right, .reveal-scale {
      opacity: 0;
      transition: opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1), transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal-up    { transform: translateY(50px); }
    .reveal-left  { transform: translateX(-60px); }
    .reveal-right { transform: translateX(60px); }
    .reveal-scale { transform: scale(0.92); }
    .revealed { opacity: 1 !important; transform: none !important; }
  </style>

  <script>
    const full = document.getElementById('content-full');
    const intensive = document.getElementById('content-intensive');
    const tabFull = document.getElementById('tab-full');
    const tabIntensive = document.getElementById('tab-intensive');

    tabFull?.addEventListener('click', () => {
      full?.classList.remove('hidden');
      intensive?.classList.add('hidden');
      tabFull.classList.add('bg-[#6B2040]', 'text-white', 'shadow-md');
      tabFull.classList.remove('text-[#6B6B6B]');
      tabIntensive?.classList.remove('bg-[#6B2040]', 'text-white', 'shadow-md');
      tabIntensive?.classList.add('text-[#6B6B6B]');
    });

    tabIntensive?.addEventListener('click', () => {
      intensive?.classList.remove('hidden');
      full?.classList.add('hidden');
      tabIntensive.classList.add('bg-[#6B2040]', 'text-white', 'shadow-md');
      tabIntensive.classList.remove('text-[#6B6B6B]');
      tabFull?.classList.remove('bg-[#6B2040]', 'text-white', 'shadow-md');
      tabFull?.classList.add('text-[#6B6B6B]');
    });

    const revealEls = document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right, .reveal-scale');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    revealEls.forEach(el => observer.observe(el));
  </script>

