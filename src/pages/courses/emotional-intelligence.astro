---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ემოციური ინტელექტი"
  description="სკოლა ნობელი — ემოციური ინტელექტი ბავშვებისთვის. შეიტყვე მეტი პროგრამის, ფილიალებისა და ფასების შესახებ."
>

  <!-- HERO -->
  <section class="bg-gradient-to-br from-[#FAF5F7] via-[#F5E8EE] to-[#EDD6DF] py-24 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#6B2040]/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#9B5A6A]/10 rounded-full translate-y-1/2 -translate-x-1/2"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="max-w-3xl reveal-up">
        <span class="text-[#9B5A6A] font-semibold text-sm uppercase tracking-widest">კურსები</span>
        <h1 class="text-4xl md:text-6xl font-bold text-[#5C1B3A] mt-3 mb-6 leading-tight">
          რა არის ემოციური ინტელექტი?
        </h1>
        <p class="text-lg text-[#5A5A5A] leading-relaxed mb-4">
          [აღწერა — კონტენტ კრეატორისგან]
        </p>
        <p class="text-lg text-[#5A5A5A] leading-relaxed mb-8">
          [დამატებითი ინფო — კონტენტ კრეატორისგან]
        </p>
        <a href="/trial-class" class="inline-block bg-[#6B2040] text-white px-8 py-4 rounded-xl font-semibold hover:bg-[#5A1A35] transition-all hover:shadow-xl hover:-translate-y-0.5 text-lg">
          უფასო საცდელი გაკვეთილი →
        </a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 1200 60" preserveAspectRatio="none" class="w-full h-14 fill-[#FDF5F8]">
        <path d="M0,30 C200,60 400,0 600,30 C800,60 1000,0 1200,30 L1200,60 L0,60 Z"/>
      </svg>
    </div>
  </section>

  <!-- STAIRS ILLUSTRATION -->
  <section class="py-16 bg-[#FDF5F8] overflow-hidden">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12 reveal-up">
        <span class="text-[#9B5A6A] font-semibold text-sm uppercase tracking-widest">განვითარების გზა</span>
        <h2 class="text-2xl md:text-3xl font-bold text-[#5C1B3A] mt-3">ემოციური ზრდის საფეხურები</h2>
      </div>
      <div class="reveal-up">
        <svg viewBox="0 0 820 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" role="img" aria-label="ემოციური განვითარების საფეხურები">

          <!-- Ground shadow -->
          <ellipse cx="410" cy="483" rx="395" ry="7" fill="#E8B0C8" opacity="0.3"/>

          <!-- Step 1 — სიხარული -->
          <rect x="15" y="408" width="118" height="70" rx="10 10 3 3" fill="#FCE4EF"/>
          <rect x="15" y="408" width="118" height="4" rx="2" fill="#F4A8CB"/>
          <text x="74" y="440" text-anchor="middle" font-size="12" fill="#9B2E5A" font-weight="700" font-family="Noto Sans Georgian, sans-serif">სიხარული</text>
          <text x="74" y="458" text-anchor="middle" font-size="10" fill="#C88AAA" font-family="sans-serif">01</text>

          <!-- Step 2 — სიყვარული -->
          <rect x="133" y="338" width="118" height="140" rx="10 10 0 0" fill="#F8C4DC"/>
          <rect x="133" y="338" width="118" height="4" rx="2" fill="#EC8AB8"/>
          <text x="192" y="370" text-anchor="middle" font-size="12" fill="#7A1A3A" font-weight="700" font-family="Noto Sans Georgian, sans-serif">სიყვარული</text>
          <text x="192" y="388" text-anchor="middle" font-size="10" fill="#B86A8A" font-family="sans-serif">02</text>

          <!-- Step 3 — ნდობა -->
          <rect x="251" y="268" width="118" height="210" rx="10 10 0 0" fill="#F0A0C6"/>
          <rect x="251" y="268" width="118" height="4" rx="2" fill="#D870A8"/>
          <text x="310" y="300" text-anchor="middle" font-size="12" fill="#6B1838" font-weight="700" font-family="Noto Sans Georgian, sans-serif">ნდობა</text>
          <text x="310" y="318" text-anchor="middle" font-size="10" fill="#A85888" font-family="sans-serif">03</text>

          <!-- Step 4 — თანაგრძნობა -->
          <rect x="369" y="198" width="118" height="280" rx="10 10 0 0" fill="#E07AA8"/>
          <rect x="369" y="198" width="118" height="4" rx="2" fill="#C84888"/>
          <text x="428" y="230" text-anchor="middle" font-size="12" fill="white" font-weight="700" font-family="Noto Sans Georgian, sans-serif">თანაგრძნობა</text>
          <text x="428" y="248" text-anchor="middle" font-size="10" fill="#F4C0D8" font-family="sans-serif">04</text>

          <!-- Step 5 — თავდაჯერება -->
          <rect x="487" y="128" width="118" height="350" rx="10 10 0 0" fill="#C8507A"/>
          <rect x="487" y="128" width="118" height="4" rx="2" fill="#A83060"/>
          <text x="546" y="160" text-anchor="middle" font-size="12" fill="white" font-weight="700" font-family="Noto Sans Georgian, sans-serif">თავდაჯერება</text>
          <text x="546" y="178" text-anchor="middle" font-size="10" fill="#F0B8CC" font-family="sans-serif">05</text>

          <!-- Step 6 — ბედნიერება -->
          <rect x="605" y="58" width="118" height="420" rx="10 10 0 0" fill="#9B2E5A"/>
          <rect x="605" y="58" width="118" height="4" rx="2" fill="#7A1A3A"/>
          <text x="664" y="90" text-anchor="middle" font-size="12" fill="white" font-weight="700" font-family="Noto Sans Georgian, sans-serif">ბედნიერება</text>
          <text x="664" y="108" text-anchor="middle" font-size="10" fill="#F0B8CC" font-family="sans-serif">06</text>

          <!-- Child figure on top step — arms raised -->
          <!-- Head -->
          <circle cx="664" cy="28" r="20" fill="white" opacity="0.95"/>
          <!-- Eyes -->
          <circle cx="657" cy="24" r="2.5" fill="#9B2E5A"/>
          <circle cx="671" cy="24" r="2.5" fill="#9B2E5A"/>
          <!-- Happy mouth -->
          <path d="M658 33 Q664 39 670 33" fill="none" stroke="#9B2E5A" stroke-width="2" stroke-linecap="round"/>
          <!-- Rosy cheeks -->
          <circle cx="653" cy="30" r="4" fill="#F4A0B8" opacity="0.55"/>
          <circle cx="675" cy="30" r="4" fill="#F4A0B8" opacity="0.55"/>
          <!-- Body -->
          <line x1="664" y1="48" x2="664" y2="58" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.95"/>
          <!-- Arms raised -->
          <line x1="664" y1="52" x2="645" y2="36" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.95"/>
          <line x1="664" y1="52" x2="683" y2="36" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.95"/>
          <!-- Sparkles -->
          <path d="M635 20 L637 16 L639 20 L643 22 L639 24 L637 28 L635 24 L631 22 Z" fill="white" opacity="0.6"/>
          <path d="M688 14 L689.5 11 L691 14 L694 15.5 L691 17 L689.5 20 L688 17 L685 15.5 Z" fill="white" opacity="0.5"/>
          <circle cx="628" cy="34" r="2.5" fill="white" opacity="0.4"/>
          <circle cx="700" cy="26" r="2" fill="white" opacity="0.4"/>

          <!-- Dashed upward arrow path along the staircase -->
          <path d="M74 405 L133 405 L133 335 L251 335 L251 265 L369 265 L369 195 L487 195 L487 125 L605 125 L605 55" fill="none" stroke="#D890B0" stroke-width="1.5" stroke-dasharray="5 4" stroke-linecap="round" opacity="0.6"/>
          <!-- Arrowhead at top -->
          <path d="M600 62 L605 55 L610 62" fill="none" stroke="#D890B0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>

        </svg>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="py-24 bg-[#6B2040] relative overflow-hidden">
    <!-- Gradient blobs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full bg-[#9B2E5A] opacity-30 blur-[120px]"></div>
      <div class="absolute -top-10 right-1/4 w-72 h-72 rounded-full bg-[#C85580] opacity-25 blur-[100px]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] rounded-full bg-[#5A1A35] opacity-30 blur-[140px]"></div>
      <div class="absolute top-1/3 -left-10 w-64 h-64 rounded-full bg-[#9B2E5A] opacity-20 blur-[90px]"></div>
      <div class="absolute bottom-1/3 -right-10 w-80 h-80 rounded-full bg-[#C85580] opacity-20 blur-[110px]"></div>
      <div class="absolute -bottom-20 left-1/4 w-72 h-72 rounded-full bg-[#A03060] opacity-25 blur-[100px]"></div>
      <div class="absolute -bottom-10 -right-20 w-96 h-96 rounded-full bg-[#9B2E5A] opacity-20 blur-[120px]"></div>
    </div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16 reveal-right">
        <span class="text-[#E8A0B4] font-semibold text-sm uppercase tracking-widest">სარგებელი</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
          რა წვლილს თამაშობს ემოციების შემეცნება ბავშვის განვითარებაში
        </h2>
        <p class="text-[#E8A0B4] text-lg max-w-2xl mx-auto">
          [ქვესათაური — კონტენტ კრეატორისგან]
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { title: 'ემოციების ამოცნობა და გამოხატვა', desc: 'ბავშვი სწავლობს საკუთარი და სხვის ემოციების ამოცნობას, სახელდებასა და ადეკვატურ გამოხატვას.', delay: '0ms', bg: 'rgba(155,46,90,0.30)', border: 'rgba(200,85,128,0.40)', text: '#E8C0CC' },
          { title: 'სოციალური კომპეტენცია', desc: 'ბავშვი ვითარდება, როგორც თანამოაზრე — სწავლობს სხვებთან კომუნიკაციას, მოსმენასა და თანამშრომლობას.', delay: '80ms', bg: 'rgba(180,60,100,0.30)', border: 'rgba(210,100,140,0.40)', text: '#E8C0CC' },
          { title: 'კონფლიქტის მოგვარება', desc: 'ბავშვი სწავლობს პრობლემების მშვიდობიანად გადაჭრას, კომპრომისის პოვნასა და ემოციების მართვას სტრესულ სიტუაციებში.', delay: '160ms', bg: 'rgba(155,46,90,0.30)', border: 'rgba(200,85,128,0.40)', text: '#E8C0CC' },
          { title: 'სტრესის მართვა', desc: 'ბავშვი ეუფლება სტრესის, შფოთვისა და ნეგატიური ემოციების გამკლავების ჯანსაღ სტრატეგიებს.', delay: '240ms', bg: 'rgba(180,60,100,0.30)', border: 'rgba(210,100,140,0.40)', text: '#E8C0CC' },
          { title: 'თანაგრძნობა (ემპათია)', desc: 'ბავშვი ვითარდება, როგორც ემპათიური პიროვნება — სწავლობს სხვის პოზიციიდან სიტუაციის შეფასებას.', delay: '320ms', bg: 'rgba(155,46,90,0.30)', border: 'rgba(200,85,128,0.40)', text: '#E8C0CC' },
          { title: 'თვითრეგულაცია და თავდაჯერება', desc: 'ბავშვი ვითარდება, როგორც დამოუკიდებელი პიროვნება — ვისაც გააჩნია საკუთარი ძალისა და შესაძლებლობების რწმენა.', delay: '400ms', bg: 'rgba(180,60,100,0.30)', border: 'rgba(210,100,140,0.40)', text: '#E8C0CC' },
        ].map((b) => (
          <div
            class="rounded-2xl p-7 flex flex-col gap-3 reveal-scale transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl"
            style={`background: ${b.bg}; border: 1px solid ${b.border}; transition-delay: ${b.delay}`}
          >
            <h3 class="text-white font-bold text-base">{b.title}</h3>
            <p class="text-sm leading-relaxed" style={`color: ${b.text}`}>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 1200 50" preserveAspectRatio="none" class="w-full h-12 fill-[#FAF8F5]">
        <path d="M0,25 C300,50 600,0 900,25 C1050,38 1150,15 1200,25 L1200,50 L0,50 Z"/>
      </svg>
    </div>
  </section>

  <!-- TOGGLE -->
  <div class="bg-[#FAF8F5] py-8 sticky top-[73px] z-40 border-b border-[#E8E4DE]">
    <div class="max-w-5xl mx-auto px-6 flex justify-center">
      <div class="flex gap-1 bg-[#E8E4DE] rounded-xl p-1">
        <button id="tab-full" class="px-8 py-3 rounded-lg font-semibold text-sm transition-all bg-[#6B2040] text-white shadow-md">
          სრული კურსი
        </button>
        <button id="tab-intensive" class="px-8 py-3 rounded-lg font-semibold text-sm transition-all text-[#6B6B6B] hover:text-[#6B2040]">
          ინტენსიური კურსი
        </button>
      </div>
    </div>
  </div>

  <!-- სრული კურსი CONTENT -->
  <div id="content-full">

    <!-- BRANCHES -->
    <section class="py-24 bg-[#FDF5F8] relative overflow-hidden">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-16 reveal-up">
          <span class="text-[#9B5A6A] font-semibold text-sm uppercase tracking-widest">ლოკაციები</span>
          <h2 class="text-3xl md:text-4xl font-bold text-[#5C1B3A] mt-3">ჩვენი ფილიალები</h2>
          <p class="text-[#6B6B6B] mt-3">აირჩიე შენთვის ყველაზე ახლომდებარე ფილიალი</p>
        </div>
        <div class="flex flex-col gap-3 reveal-left">
          {[
            { name: 'საბურთალო', address: 'შ. ნუცუბიძის 16 ა', url: 'https://maps.app.goo.gl/V11VP5ibXxsrDmLZ7' },
            { name: 'საბურთალო', address: 'ვაჟა ფშაველას გამზირი #85', url: 'https://maps.app.goo.gl/W2D2DaXScNKCTmQx7' },
            { name: 'გლდანი', address: 'გობრონიძის ქუჩა #1', url: 'https://maps.app.goo.gl/o7ZNEDm6dFr1z2xY8' },
            { name: 'დიდი დიღომი', address: 'პეტრე იბერის #7 (სკოლა სახელოვნო)', url: 'https://maps.app.goo.gl/S8SKRR9JRm13AzQ19' },
          ].map((branch) => (
            <a href={branch.url} target="_blank" rel="noopener" class="flex items-center justify-between bg-white border border-[#F0D0DC] rounded-2xl px-6 py-5 hover:shadow-md hover:border-[#6B2040]/30 hover:-translate-y-0.5 transition-all group">
              <div class="flex items-center gap-5">
                <div class="w-10 h-10 bg-[#6B2040]/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-[#6B2040]/15 transition-colors">
                  <svg class="w-5 h-5 text-[#6B2040]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-bold text-[#5C1B3A] text-base">{branch.name}</div>
                  <div class="text-sm text-[#6B6B6B] mt-0.5">{branch.address}</div>
                </div>
              </div>
              <div class="flex items-center gap-2 text-[#9B2E5A] text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
                რუკაზე ნახვა
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- PRICING + DISCOUNTS -->
    <section class="overflow-hidden">
      <div class="flex flex-col lg:flex-row min-h-[420px]">
        <div class="lg:w-3/5 bg-white px-10 py-16 flex flex-col justify-center">
          <div class="mb-8 text-center">
            <span class="text-[#9B5A6A] font-semibold text-sm uppercase tracking-widest">ღირებულება</span>
            <h2 class="text-2xl font-bold text-[#5C1B3A] mt-2">ფასები</h2>
            <p class="text-[#6B6B6B] text-xs mt-1">გაკვეთილები კვირაში 2-ჯერ</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-sm mx-auto w-full">
            <div class="rounded-xl p-5 flex flex-col items-center gap-2 bg-[#FDF5F8] border border-[#F0D0DC] hover:shadow-md hover:-translate-y-0.5 transition-all text-center">
              <div class="text-xs font-semibold text-[#6B6B6B] uppercase tracking-wide leading-tight">სამუშაო დღეები</div>
              <div class="flex items-end gap-0.5 mt-1">
                <span class="text-4xl font-bold text-[#5C1B3A]">120</span>
                <span class="text-sm font-semibold mb-0.5 text-[#6B6B6B]">₾</span>
              </div>
              <div class="text-xs text-[#9B9B9B]">ორშაბათი–პარასკევი</div>
              <div class="h-px bg-[#F0D0DC] my-1 w-full"></div>
              <a href="/trial-class" class="w-full text-center py-2 rounded-lg font-semibold text-xs bg-[#6B2040] text-white hover:bg-[#9B2E5A] transition-all">დარეგისტრირდი</a>
            </div>
            <div class="relative rounded-xl p-5 flex flex-col items-center gap-2 bg-[#6B2040] shadow-lg text-center">
              <div class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-[#C0392B] text-white font-bold px-2.5 py-0.5 rounded-full whitespace-nowrap" style="font-size:10px">პოპულარული</div>
              <div class="text-xs font-semibold text-[#E8A0B4] uppercase tracking-wide leading-tight">შაბათ-კვირა</div>
              <div class="flex items-end gap-0.5 mt-1">
                <span class="text-4xl font-bold text-white">140</span>
                <span class="text-sm font-semibold mb-0.5 text-[#E8A0B4]">₾</span>
              </div>
              <div class="text-xs text-[#E8A0B4]">შაბათი–კვირა</div>
              <div class="h-px bg-white/20 my-1 w-full"></div>
              <a href="/trial-class" class="w-full text-center py-2 rounded-lg font-semibold text-xs bg-white text-[#6B2040] hover:bg-[#FDF5F8] transition-all">დარეგისტრირდი</a>
            </div>
          </div>
        </div>
