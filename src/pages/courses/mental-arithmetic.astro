  <style>
    @keyframes float-slow {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-18px) rotate(5deg); }
    }
    @keyframes float-slow-r {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-12px) rotate(-4deg); }
    }
    .shape-float { animation: float-slow 8s ease-in-out infinite; }
    .shape-float-r { animation: float-slow-r 10s ease-in-out infinite; }
    .reveal-up, .reveal-left, .reveal-right, .reveal-scale {
      opacity: 0;
      transition: opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1), transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal-up    { transform: translateY(50px); }
    .reveal-left  { transform: translateX(-60px); }
    .reveal-right { transform: translateX(60px); }
    .reveal-scale { transform: scale(0.92); }
    .revealed { opacity: 1 !important; transform: none !important; }
  </style>

  <script>
    const classroom = document.getElementById('content-classroom');
    const online = document.getElementById('content-online');
    const tabClassroom = document.getElementById('tab-classroom');
    const tabOnline = document.getElementById('tab-online');

    tabClassroom?.addEventListener('click', () => {
      classroom?.classList.remove('hidden');
      online?.classList.add('hidden');
      tabClassroom.classList.add('bg-[#1B3A5C]', 'text-white', 'shadow-md');
      tabClassroom.classList.remove('text-[#6B6B6B]');
      tabOnline?.classList.remove('bg-[#1B3A5C]', 'text-white', 'shadow-md');
      tabOnline?.classList.add('text-[#6B6B6B]');
    });

    tabOnline?.addEventListener('click', () => {
      online?.classList.remove('hidden');
      classroom?.classList.add('hidden');
      tabOnline.classList.add('bg-[#1B3A5C]', 'text-white', 'shadow-md');
      tabOnline.classList.remove('text-[#6B6B6B]');
      tabClassroom?.classList.remove('bg-[#1B3A5C]', 'text-white', 'shadow-md');
      tabClassroom?.classList.add('text-[#6B6B6B]');
    });

    const revealEls = document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right, .reveal-scale');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    revealEls.forEach(el => observer.observe(el));
  </script>

