---
---
<nav class="bg-[#FAF8F5]/95 backdrop-blur-sm border-b border-[#E8E4DE] sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/">
      <img src="/logo.png" alt="სკოლა ნობელი" class="h-14 w-auto" />
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="/" class="text-[#2C2C2C] hover:text-[#1B3A5C] font-medium transition-colors text-sm">მთავარი</a>

      <!-- Courses dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 text-[#2C2C2C] hover:text-[#1B3A5C] font-medium text-sm transition-colors">
          კურსები
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-56 bg-white rounded-xl shadow-xl border border-[#E8E4DE] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50">
          <div class="absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-4 bg-white border-l border-t border-[#E8E4DE] rotate-45"></div>
          <a href="/courses/mental-arithmetic" class="flex items-center gap-3 px-5 py-4 text-sm text-[#2C2C2C] hover:bg-[#FAF8F5] hover:text-[#1B3A5C] rounded-t-xl transition-colors font-medium">
            <div class="w-8 h-8 bg-[#1B3A5C]/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#1B3A5C]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
            </div>
            მენტალური არითმეტიკა
          </a>
          <div class="h-px bg-[#E8E4DE] mx-4"></div>
          <a href="/courses/emotional-intelligence" class="flex items-center gap-3 px-5 py-4 text-sm text-[#2C2C2C] hover:bg-[#FAF8F5] hover:text-[#1B3A5C] rounded-b-xl transition-colors font-medium">
            <div class="w-8 h-8 bg-[#4A7C59]/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#4A7C59]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            ემოციური ინტელექტი
          </a>
        </div>
      </div>

      <a href="/about" class="text-[#2C2C2C] hover:text-[#1B3A5C] font-medium transition-colors text-sm">ჩვენ შესახებ</a>
      <a href="/events" class="text-[#2C2C2C] hover:text-[#1B3A5C] font-medium transition-colors text-sm">ღონისძიებები</a>
      <a href="/blog" class="text-[#2C2C2C] hover:text-[#1B3A5C] font-medium transition-colors text-sm">ბლოგი</a>
      <a href="/contact" class="text-[#2C2C2C] hover:text-[#1B3A5C] font-medium transition-colors text-sm">კონტაქტი</a>
    </div>
    <a href="/trial-class" class="bg-[#C0392B] text-white px-5 py-2.5 rounded-lg font-medium hover:bg-[#A93226] transition-all hover:shadow-lg text-sm">
      უფასო გაკვეთილი →
    </a>
  </div>
</nav>